rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles
    match /users/{userId} {
      // Anyone can read user profiles (for search)
      allow read: if true;
      
      // Only the user themselves can write/edit their profile
      allow write: if request.auth != null && request.auth.uid == userId;

      // Teams subcollection (friend links)
      match /teams/{teamId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Requests (Invites)
    match /requests/{requestId} {
      allow read: if request.auth != null && (
        resource.data.fromUserId == request.auth.uid || 
        resource.data.toUserId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.fromUserId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.toUserId == request.auth.uid ||
        resource.data.fromUserId == request.auth.uid
      );
    }

    // Projects
    match /projects/{projectId} {
      allow read: if request.auth != null;
      
      allow create: if request.auth != null && (
        (resource == null && request.resource.data.ownerId == request.auth.uid) ||
        false
      );

      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        (
          request.auth.uid in resource.data.editorIds &&
          request.resource.data.ownerId == resource.data.ownerId &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.collaborators == resource.data.collaborators &&
          request.resource.data.collaboratorIds == resource.data.collaboratorIds &&
          request.resource.data.editorIds == resource.data.editorIds &&
          request.resource.data.invited == resource.data.invited
        )
      );

      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    
    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
